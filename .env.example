# Discord OAuth2 — create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord-callback

# Blade's bot API — ask Blade for the current secret
BOT_API_URL=https://enmityexe.sparkedservers.us/moderation/callback
BOT_API_SECRET=ask_blade_for_current_secret

# Session signing secret — generate with: openssl rand -hex 32
SESSION_SECRET=change_this_to_a_random_32_char_string

# Exposed to the browser (used to build the OAuth URL on the login page)
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_client_id_here
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord-callback
